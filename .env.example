# Prenatal Yoga AI Environment Variables
# Copy to .env and fill in secrets/keys

# Database (Docker uses postgres; local fallback sqlite)
DATABASE_URL=sqlite:///./prenatal.db
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/prenatal_yoga

# Security
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-min32chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Paths (relative to backend container; mounted via docker-compose)
POSE_MODEL_PATH=/models/pose_classifier.pkl
YOGA_VIDEOS_CSV=/data/yoga_videos.csv
KNOWLEDGE_CHUNKS_PATH=/data/knowledge/prenatal_qa_chunks.txt

# OpenAI (required for RAG chat; get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=your-openai-api-key-here

# CORS origins for frontend
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:3000
